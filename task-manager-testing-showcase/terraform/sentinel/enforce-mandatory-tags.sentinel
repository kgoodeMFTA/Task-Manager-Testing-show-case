import "tfplan/v2" as tfplan

# Sentinel policy enforced by Terraform Enterprise on every plan/apply.
# Requires the given tags on the resource types below before a run is
# allowed to proceed.

mandatory_tags = ["Project", "Owner", "Environment"]

taggable_types = [
  "aws_lb",
  "aws_ecs_cluster",
  "aws_ecs_service",
  "aws_ecs_task_definition",
  "aws_security_group",
  "aws_lb_target_group",
]

resources_to_check = filter tfplan.resource_changes as _, rc {
  rc.mode is "managed" and
  rc.type in taggable_types and
  (rc.change.actions contains "create" or rc.change.actions contains "update")
}

tags_are_valid = rule {
  all resources_to_check as _, r {
    all mandatory_tags as tag {
      r.change.after.tags else {} contains tag
    }
  }
}

main = rule {
  tags_are_valid
}
